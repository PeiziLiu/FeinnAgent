# FeinnAgent Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM Provider API Keys (at least one required)
# =============================================================================

# OpenAI
# OPENAI_API_KEY=sk-...

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2023-12-01-preview

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # Optional

# Google Gemini
# GEMINI_API_KEY=...

# Ollama (local models, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434

# vLLM (self-hosted or managed deployment)
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_API_KEY=...  # Optional: if vLLM is configured with API key auth

# SiliconFlow (中国大模型 API 平台)
# SILICONFLOW_API_KEY=sk-...
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1  # Optional

# =============================================================================
# Model Configuration
# =============================================================================

# Default model to use (format: provider/model-name)
# DEFAULT_MODEL=anthropic/claude-sonnet-4

# API mode: "standard" or "azure"
# API_MODE=standard

# =============================================================================
# Optional Integrations
# =============================================================================

# Brave Search API (for web search tool)
# BRAVE_API_KEY=...

# Firecrawl API (for web scraping)
# FIRECRAWL_API_KEY=...

# Browserbase (for browser automation)
# BROWSERBASE_API_KEY=...
# BROWSERBASE_PROJECT_ID=...

# Modal (for sandboxed code execution)
# MODAL_TOKEN_ID=...
# MODAL_TOKEN_SECRET=...

# Daytona (for sandboxed code execution)
# DAYTONA_API_KEY=...
# DAYTONA_SERVER_URL=...

# =============================================================================
# Messaging Platform Gateways (Optional)
# =============================================================================

# Telegram Bot
# TELEGRAM_BOT_TOKEN=...

# Discord Bot
# DISCORD_BOT_TOKEN=...

# Slack Bot
# SLACK_BOT_TOKEN=...
# SLACK_SIGNING_SECRET=...

# =============================================================================
# Advanced Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Log file path (optional, logs to console only if not set)
# LOG_FILE=~/.feinn/feinn.log

# Enable debug mode (verbose logging, no permission prompts)
# DEBUG=false

# Default permission mode: ASK, AUTO, ACCEPT_ALL
# PERMISSION_MODE=ACCEPT_ALL

# Max iterations per request (safety limit)
# MAX_ITERATIONS=90

# Enable trajectory saving for debugging
# SAVE_TRAJECTORIES=false

# =============================================================================
# Enterprise / Production Settings
# =============================================================================

# Enable audit logging to file
# AUDIT_LOG_PATH=/var/log/feinn-agent/audit.log

# Custom skills directory (default: ~/.feinn/skills)
# CUSTOM_SKILLS_PATH=/opt/feinn/skills

# Memory database path (default: ~/.feinn/memory.db)
# MEMORY_DB_PATH=/opt/feinn/data/memory.db

# Task database path (default: ~/.feinn/tasks.db)
# TASK_DB_PATH=/opt/feinn/data/tasks.db

# =============================================================================
# Example Configurations
# =============================================================================

# --- Example 1: Local Development with Ollama ---
# OLLAMA_BASE_URL=http://localhost:11434
# DEFAULT_MODEL=ollama/llama3.2
# PERMISSION_MODE=ACCEPT_ALL
# DEBUG=true

# --- Example 2: Production with Claude ---
# ANTHROPIC_API_KEY=sk-ant-...
# DEFAULT_MODEL=anthropic/claude-sonnet-4
# PERMISSION_MODE=ASK
# AUDIT_LOG_PATH=/var/log/feinn-agent/audit.log

# --- Example 3: Multi-Provider Setup ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# DEFAULT_MODEL=anthropic/claude-sonnet-4
# BRAVE_API_KEY=...

# --- Example 4: vLLM with Qwen3.5-35B ---
# VLLM_BASE_URL=http://localhost:8000/v1
# DEFAULT_MODEL=vllm/Qwen/Qwen3.5-35B-Instruct
# MAX_ITERATIONS=50
# PERMISSION_MODE=ASK
